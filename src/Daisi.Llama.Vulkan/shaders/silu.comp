#version 450

layout(local_size_x = 256) in;

layout(push_constant) uniform PushConstants {
    uint n;
};

layout(set = 0, binding = 0) buffer OutputBuf { float output_data[]; };
layout(set = 0, binding = 1) buffer InputBuf { float input_data[]; };

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= n) return;
    float x = input_data[idx];
    output_data[idx] = x / (1.0 + exp(-x));
}
